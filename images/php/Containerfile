FROM php:8.3-fpm

LABEL org.opencontainers.image.source="https://github.com/tavp-stack/tavpbox"
LABEL org.opencontainers.image.description="TAVPBox PHP 8.3 with Nginx, MariaDB, Redis, Mailpit"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Jakarta

# Install system packages
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
    nginx \
    mariadb-server mariadb-client \
    redis-server \
    libpq-dev \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libzip-dev \
    libsqlite3-dev \
    locales \
    tzdata \
    curl wget git unzip \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions (only missing ones)
RUN docker-php-ext-install mysqli pdo_mysql pdo_pgsql gd zip

# Install Phalcon
RUN pecl channel-update pecl.php.net 2>/dev/null \
    && pecl install phalcon 2>/dev/null || true \
    && echo "extension=phalcon.so" > /usr/local/etc/php/conf.d/phalcon.ini

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Install Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y -qq --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Mailpit
RUN curl -sL https://github.com/axllent/mailpit/releases/download/v1.21.1/mailpit-linux-amd64.tar.gz | tar xz -C /usr/local/bin/

# Configure nginx
COPY nginx.conf /etc/nginx/sites-available/default

# Start script
COPY start.sh /usr/local/bin/tavpbox-start.sh
RUN chmod +x /usr/local/bin/tavpbox-start.sh

CMD ["/usr/local/bin/tavpbox-start.sh"]
